{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "rootDir": "./src/"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules/", "coverage/", "dist/"]
}
